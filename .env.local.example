# Resend — contact form email delivery
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=

# Giscus — GitHub Discussions comments on blog posts
# Generate at https://giscus.app (repo: davideimola/davideimola.dev)
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Cloudflare Turnstile — anti-spam on contact form
# Generate at https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
